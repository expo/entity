{
  "name": "@expo/entity-cache-adapter-redis",
  "version": "0.63.0",
  "description": "Redis cache adapter for @expo/entity",
  "keywords": [
    "entity"
  ],
  "license": "MIT",
  "author": "Expo",
  "files": [
    "build",
    "!*.tsbuildinfo",
    "!__*",
    "src"
  ],
  "type": "module",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "prepack": "rm -rf build && yarn build",
    "clean": "yarn build --clean",
    "lint": "yarn run --top-level oxlint --type-aware src",
    "lint-fix": "yarn lint --fix",
    "test": "yarn test:all --rootDir $(pwd)",
    "integration": "yarn integration:all --rootDir $(pwd)"
  },
  "dependencies": {
    "@expo/entity": "workspace:^"
  },
  "devDependencies": {
    "@expo/batcher": "1.0.0",
    "@expo/entity-testing-utils": "workspace:^",
    "@jest/globals": "30.3.0",
    "ioredis": "5.10.1",
    "ts-mockito": "2.6.1",
    "typescript": "6.0.2"
  },
  "peerDependencies": {
    "ioredis": ">=5"
  },
  "engines": {
    "node": ">=18"
  }
}
