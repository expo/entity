{
  "name": "@expo/entity-full-integration-tests",
  "version": "0.63.0",
  "private": true,
  "description": "Full redis and knex integration tests for the entity framework",
  "keywords": [
    "entity"
  ],
  "license": "MIT",
  "author": "Expo",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "clean": "yarn build --clean",
    "lint": "yarn run --top-level oxlint --type-aware src",
    "lint-fix": "yarn lint --fix",
    "integration": "yarn integration:all --rootDir $(pwd)"
  },
  "dependencies": {
    "@expo/entity": "workspace:^",
    "@expo/entity-cache-adapter-redis": "workspace:^",
    "@expo/entity-database-adapter-knex": "workspace:^"
  },
  "devDependencies": {
    "@jest/globals": "30.3.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
