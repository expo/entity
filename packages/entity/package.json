{
  "name": "@expo/entity",
  "version": "0.62.0",
  "description": "A privacy-first data model",
  "files": [
    "build",
    "!*.tsbuildinfo",
    "!__*",
    "src"
  ],
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "prepack": "rm -rf build && yarn build",
    "clean": "yarn build --clean",
    "lint": "yarn run --top-level eslint src",
    "lint-fix": "yarn run lint --fix",
    "test": "yarn test:all --rootDir $(pwd)"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "entity"
  ],
  "author": "Expo",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@expo/results": "^1.0.0",
    "dataloader": "^2.2.3",
    "invariant": "^2.2.4"
  },
  "devDependencies": {
    "@jest/globals": "30.3.0",
    "@types/invariant": "2.2.37",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.12.0",
    "lodash-es": "4.17.23",
    "ts-mockito": "2.6.1",
    "typescript": "5.9.3",
    "uuid": "13.0.0"
  }
}
